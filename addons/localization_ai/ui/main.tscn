[node name="ParallelLbl" type="Label" parent="Tabs/Graph/Toolbar" unique_id=2101010101]
layout_mode = 2
tooltip_text = "How many independent chains (Source → Translate → Export branches) run at the same time. This does NOT control concurrency within a single file — for that, see the Translate node's '⚡ Parallel requests' setting. The two stack: 2 chains × 4 requests = 8 in-flight calls total.

Useful when:
• Multiple Translate nodes exist (e.g. different models or providers).
• Multiple File / Directory Sources feed separate Translate nodes.

Has no effect on a single Directory Source feeding one Translate node — those files queue through the same node sequentially regardless of this value."
text = "Parallel chains:"

