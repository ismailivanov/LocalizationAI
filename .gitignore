# Godot 4+ specific ignores
.godot/
.import/

# Imported translations (generated from CSV)
export.cfg
export_presets.cfg

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Third-party / vendored addons (not part of this project)
addons/godot_ai/
addons/kenyoni/

# Example folder is local-only — contains real translation runs and
# occasionally API-key-bearing artifacts. Not safe to commit.
addons/localization_ai/example/

# System / editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Python cache (translate.py is stdlib-only, but just in case)
__pycache__/
*.py[cod]
*.pyo

# Release archives built by `git archive` for GitHub releases
LocalizationAI-v*.zip
